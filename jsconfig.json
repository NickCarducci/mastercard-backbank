{
  "compilerOptions": {
    "target": "es2017",
    "allowSyntheticDefaultImports": false,
    "baseUrl": "./",
    "paths": {
      "assert": "assert/",
      "buffer": "buffer/",
      "crypto": "crypto-browserify",
      "http": "stream-http",
      "https": "https-browserify",
      "path": "path-browserify",
      "querystring": "querystring-es3",
      "stream": "stream-browserify",
      "url": "url/",
      "util": "util/",
      "zlib": "browserify-zlib"
    }
  },
  "exclude": ["node_modules", "dist"]
}
